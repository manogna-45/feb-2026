class Employee{
    String name;
    int salary;

    Employee(String name, int salary){
        this.name = name;
        this.salary = salary;
    }
    void display(){
        System.out.println(name + " earns " + salary);
    }
    public static void main(String[] args) {
        Employee e1= new Employee("Manogna", 200000);
        e1.display();
    }
}
